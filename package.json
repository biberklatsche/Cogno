{
  "name": "Cogno2",
  "version": "0.1.0",
  "license": "FSL-1.1-MIT",
  "licenseText": "SEE LICENSE IN LICENSE",
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:pro": "ng build --configuration pro",
    "build:community": "ng build --configuration community",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "pnpm workspace:lint && pnpm lint:architecture",
    "lint:architecture": "depcruise --config .dependency-cruiser.cjs \"src/app/src/**/*.ts\" \"src/core-sdk/**/*.ts\" \"src/core-host/**/*.ts\" \"src/features-community/**/*.ts\" \"src/features-pro/**/*.ts\"",
    "workspace:build": "pnpm -r --if-present run build",
    "workspace:test": "pnpm -r --if-present run test",
    "workspace:lint": "pnpm -r --if-present run lint",
    "watch": "ng build --watch --configuration development",
    "tauri": "tauri",
    "tauri:build:pro": "tauri build --config src-tauri/tauri.pro.conf.json",
    "tauri:build:community": "tauri build --config src-tauri/tauri.community.conf.json",
    "release": "node ./scripts/build-tauri-macos-signed-notarized.mjs",
    "generate-icon": "tauri icon ./icon/icon.png"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.1",
    "@angular/common": "21.2.1",
    "@angular/compiler": "21.2.1",
    "@angular/core": "21.2.1",
    "@angular/forms": "21.2.1",
    "@angular/platform-browser": "21.2.1",
    "@angular/platform-browser-dynamic": "21.2.1",
    "@ctrl/tinycolor": "4.2.0",
    "@mdi/js": "7.4.47",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "2.3.2",
    "@tauri-apps/plugin-fs": "2.4.5",
    "@tauri-apps/plugin-log": "2.8.0",
    "@tauri-apps/plugin-notification": "2.3.1",
    "@tauri-apps/plugin-opener": "2.5.3",
    "@tauri-apps/plugin-os": "2.3.2",
    "@tauri-apps/plugin-process": "2.3.1",
    "@tauri-apps/plugin-sql": "2.3.1",
    "@tauri-apps/plugin-window-state": "2.4.1",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-ligatures": "0.10.0",
    "@xterm/addon-search": "0.16.0",
    "@xterm/addon-unicode11": "0.9.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "6.0.0",
    "grammy": "1.41.1",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zod": "4.3.5"
  },
  "devDependencies": {
    "@angular/build": "21.2.1",
    "@angular/cli": "21.2.1",
    "@angular/compiler-cli": "21.2.1",
    "@tauri-apps/cli": "2.10.1",
    "@vitest/coverage-v8": "4.0.18",
    "dependency-cruiser": "17.3.8",
    "happy-dom": "20.8.3",
    "typescript": "~5.9.3",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.0.18"
  }
}
