# Optional upload target for rclone
COGNO_RELEASE_RCLONE_REMOTE=storage
COGNO_RELEASE_RCLONE_BASE_PATH=cogno2

# Optional macOS signing and notarization
COGNO_APPLE_SIGNING_IDENTITY=Developer ID Application: Example Name (TEAMID1234)
COGNO_APPLE_ID=your-apple-id@example.com
COGNO_APPLE_TEAM_ID=TEAMID1234
COGNO_APPLE_APP_PASSWORD=app-specific-password
