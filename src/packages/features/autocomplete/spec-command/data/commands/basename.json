{
  "name": "basename",
  "description": "Return filename portion of pathname",
  "providers": [
    {
      "providerId": "filesystem",
      "source": "fs-path",
      "baseScore": 58,
      "params": {
        "kinds": [
          "file",
          "directory"
        ],
        "appendSlashToDirectories": true,
        "continueSuggestions": true
      }
    }
  ],
  "options": [
    {
      "name": "-a",
      "description": "Treat every argument as a string"
    },
    {
      "name": "-s",
      "description": "Suffix to remove from string",
      "args": [
        {
          "name": "suffix"
        }
      ]
    }
  ]
}
