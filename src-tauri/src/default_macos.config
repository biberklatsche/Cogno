keybind=Command+P=show_actions
keybind=Command+F1=bring_to_front
keybind=Control+Tab=change_tab
keybind=Alt+Right=next_tab
keybind=Alt+Left=previous_tab
keybind=Command+Alt+C=clear_buffer
keybind=Command+W=close_tab
keybind=Command+Shift+W=close_other_tabs
keybind=Control+Shift+Q=close_all_tabs
keybind=Command+Shift+<=split_vertical
keybind=Command+Shift+-=split_horizontal
keybind=Command+Shift+U=unsplit
keybind=Command+Shift+P=swap_panes
keybind=Control+Shift+C=abort_all_tasks
keybind=performable:Control+C=copy
keybind=Command+X=cut
keybind=Command+F=find
keybind=Control+Y=clear_line
keybind=Control+M=clear_line_to_end
keybind=Control+N=clear_line_to_start
keybind=Control+,=delete_previous_word
keybind=Control+.=delete_next_word
keybind=Control+Right=go_to_next_word
keybind=Control+Left=go_to_previous_word
keybind=Control+T=new_tab
keybind=Control+Shift+D=duplicate_tab
keybind=Command+V=paste
keybind=Control+Space=show_autocompletion
keybind=Command+Shift+H=show_paste_history
keybind=Control+K=show_key_tips
keybind=Control+Shift+K=show_context_key_tips
keybind=Control+Alt+Right=next_argument
keybind=Control+Alt+Left=previous_argument
keybind=Command+Shift+S=open_settings
keybind=Command+1=open_shell_1
keybind=Command+2=open_shell_2
keybind=Command+3=open_shell_3
keybind=Command+4=open_shell_4
keybind=Command+5=open_shell_5
keybind=Command+6=open_shell_6
keybind=Command+7=open_shell_7
keybind=Command+8=open_shell_8
keybind=Command+9=open_shell_9
keybind=Control+Shift+Up=scroll_to_previous_command
keybind=Control+Shift+Down=scroll_to_next_command
keybind=Control+Alt+Up=scroll_to_previous_bookmark
keybind=Control+Alt+Down=scroll_to_next_bookmark
keybind=Shift+Right=select_text_right
keybind=Shift+Left=select_text_left
keybind=Control+Shift+Right=select_word_right
keybind=Control+Shift+Left=select_word_left
keybind=Shift+End=select_text_to_end_of_line
keybind=Shift+Home=select_text_to_start_of_line
keybind=Control+Shift+F12=open_dev_tools
keybind=Control+Shift+F=inject_password

scrollback_lines=10000
enable_webgl=false

font.enable_ligatures=false
font.family=monospace
font.size=14
font.weight=normal
font.weight_bold=bold

color.background=#0e1925
color.foreground=#ffffff
color.black=#32465c
color.blue=#34bbfe
color.cyan=#32d8c1
color.green=#11d894
color.magenta=#e465d9
color.red=#fd1155
color.white=#eeeeee
color.yellow=#fede55
color.bright-black=#32465c
color.bright-blue=#34bbfe
color.bright-cyan=#32d8c1
color.bright-green=#11d894
color.bright-magenta=#e465d9
color.bright-red=#fd1155
color.bright-white=#eeeeee
color.bright-yellow=#fede55
color.highlight=#34bbfe

cursor.color=#34bbfe
cursor.blink=true
cursor.style=bar
cursor.width=4

padding.remove_on_full_screen_app=true
padding.left=1rem
padding.right=1rem
padding.top=1rem
padding.bottom=1rem

background_image.path=
background_image.opacity=80
background_image.blur=0

shell.1.args=
shell.1.path=
shell.1.env=
shell.1.shell_type=
shell.1.working_dir=
