keybind = Ctrl+C=[performable]copy
keybind = Ctrl+X=[performable]cut
keybind = Ctrl+Space=trigger_autocomplete
keybind = Shift+Space=cycle_completion_mode
keybind = Ctrl+T=new_tab
keybind = Ctrl+Shift+W=close_tab
keybind = Ctrl+PageDown=select_next_tab
keybind = Ctrl+PageUp=select_previous_tab
keybind = Ctrl+Shift+PageDown=select_next_pane
keybind = Ctrl+Shift+PageUp=select_previous_pane
keybind = Control+V=paste
keybind = Ctrl+R=split_right
keybind = Ctrl+Shift+R=split_left
keybind = Ctrl+D=split_down
keybind = Ctrl+Shift+D=split_up
keybind = Ctrl+Shift+Enter=maximize_pane
keybind = Ctrl+Shift+Enter=minimize_pane
keybind = Ctrl+W=close_terminal
keybind = Ctrl+Alt+C=clear_buffer
keybind = Alt+W=close_other_tabs
keybind = Ctrl+Shift+Q=close_all_tabs
keybind = Ctrl+Alt+W=open_workspace
keybind = Ctrl+Alt+N=open_notification
keybind = Ctrl+Q=quit
keybind = Ctrl+N=new_window
keybind = Ctrl+Shift+Alt+W=close_window
keybind = Ctrl+,=open_config
keybind = Ctrl+P=open_command_palette
keybind = Ctrl+F=open_terminal_search
keybind = Ctrl+Y=clear_line

keybind = Ctrl+K=clear_line_to_end
keybind = Ctrl+L=clear_line_to_start
keybind = Ctrl+Alt+Left=delete_previous_word
keybind = Ctrl+Alt+Right=delete_next_word
keybind = Ctrl+Right=go_to_next_word
keybind = Ctrl+Left=go_to_previous_word

keybind = Shift+Right=select_text_right
keybind = Shift+Left=select_text_left
keybind = Ctrl+Shift+Right=select_word_right
keybind = Ctrl+Shift+Left=select_word_left
keybind = Ctrl+Shift+M=select_text_to_end_of_line
keybind = Ctrl+Shift+N=select_text_to_start_of_line
keybind = Ctrl+A=select_all

keybind = Ctrl+1=select_tab_1
keybind = Ctrl+2=select_tab_2
keybind = Ctrl+3=select_tab_3
keybind = Ctrl+4=select_tab_4
keybind = Ctrl+5=select_tab_5
keybind = Ctrl+6=select_tab_6
keybind = Ctrl+7=select_tab_7
keybind = Ctrl+8=select_tab_8
keybind = Ctrl+9=select_tab_9
keybind = Ctrl+Alt+0=select_workspace_default
keybind = Ctrl+Alt+1=select_workspace_1
keybind = Ctrl+Alt+2=select_workspace_2
keybind = Ctrl+Alt+3=select_workspace_3
keybind = Ctrl+Alt+4=select_workspace_4
keybind = Ctrl+Alt+5=select_workspace_5
keybind = Ctrl+Alt+6=select_workspace_6
keybind = Ctrl+Alt+7=select_workspace_7
keybind = Ctrl+Alt+8=select_workspace_8
keybind = Ctrl+Alt+9=select_workspace_9
keybind = Ctrl+Shift+1=open_shell_1
keybind = Ctrl+Shift+2=open_shell_2
keybind = Ctrl+Shift+3=open_shell_3
keybind = Ctrl+Shift+4=open_shell_4
keybind = Ctrl+Shift+5=open_shell_5
keybind = Ctrl+Shift+6=open_shell_6
keybind = Ctrl+Shift+7=open_shell_7
keybind = Ctrl+Shift+8=open_shell_8
keybind = Ctrl+Shift+9=open_shell_9

enable_watch_config = true

font.enable_ligatures = false
font.family = monospace
font.size = 14
font.weight = normal
font.weight_bold = bold
font.custom_glyphs = true
font.draw_bold_text_in_bright_colors = false
font.rescale_overlapping_glyphs = false

font.app.size = 14
font.app.family = sans-serif

color.background = 0e1925
color.foreground = ffffff
color.black = 32465c
color.blue = 34bbfe
color.cyan = 32d8c1
color.green = 11d894
color.magenta = e465d9
color.red = fd1155
color.white = eeeeee
color.yellow = fede55
color.bright_black = 32465c
color.bright_blue = 34bbfe
color.bright_cyan = 32d8c1
color.bright_green = 11d894
color.bright_magenta = e465d9
color.bright_red = fd1155
color.bright_white = eeeeee
color.bright_yellow = fede55
color.highlight = 34bbfe

scrollbar.overview_ruler_border_color = 0e192500
scrollbar.slider_color = 32465c66
scrollbar.slider_hover_color = 32465c
scrollbar.slider_active_color = 32465c
scrollbar.width = 6
scrollbar.sensitivity = 1
scrollbar.scroll_on_user_input = true
scrollbar.smooth_scroll_duration = 0
scrollbar.scrollback_lines = 100000
scrollbar.fast_scroll_sensitivity = 2

cursor.color = 34bbfecc
cursor.accent_color = 34bbfe66
cursor.blink = true
cursor.style = bar
cursor.width = 4
cursor.alt_click_moves_cursor = true

padding.remove_on_full_screen_app = false
padding.left = 0.5
padding.right = 0.5
padding.top = 0
padding.bottom = 0.5

background_image.path =
background_image.opacity = 80
background_image.blur = 0

menu.opacity = 80

selection.clear_on_copy = false
selection.background_color = 34bbfecc
selection.inactive_background_color = 34bbfe66
selection.right_click_selects_word = false

prompt.active = default
prompt.profile.default.order = [dir,error_code,ok_code,duration]

prompt.segment.user.field = user
prompt.segment.user.padding_left = 5
prompt.segment.user.foreground = black
prompt.segment.user.background = yellow
prompt.segment.user.bold = false
prompt.segment.user.margin_left = -5

prompt.segment.emoji.text = 🎲
prompt.segment.emoji.size = 10

prompt.segment.at.text = @
prompt.segment.at.foreground = black
prompt.segment.at.background = green

prompt.segment.dir.field = directory
prompt.segment.dir.foreground = black
prompt.segment.dir.background = blue
prompt.segment.dir.padding_left = 5
prompt.segment.dir.padding_right = 5
prompt.segment.dir.radius_right = 5

prompt.segment.machine.field = machine
prompt.segment.machine.foreground = black
prompt.segment.machine.background = green
prompt.segment.machine.padding_right = 5
prompt.segment.machine.radius_right = 5

prompt.segment.duration.field = duration
prompt.segment.duration.foreground = black
prompt.segment.duration.margin_left = 5
prompt.segment.duration.format = timespan

prompt.segment.error_code.text =❗
prompt.segment.error_code.radius_left = 5
prompt.segment.error_code.radius_right = 5
prompt.segment.error_code.margin_left = 5
prompt.segment.error_code.when = returnCode!=0
prompt.segment.error_code.padding_right = 2
prompt.segment.error_code.padding_left = 2

prompt.segment.ok_code.text =  ✔️️
prompt.segment.ok_code.radius_left = 5
prompt.segment.ok_code.radius_right = 5
prompt.segment.ok_code.margin_left = 5
prompt.segment.ok_code.when = returnCode==0
prompt.segment.ok_code.padding_right = 2
prompt.segment.ok_code.padding_left = 2

workspace.mode  = visible
notification.mode  = visible
notification.highlight_terminal_on_activity = true
notification.long_running_commands.enabled = false
notification.long_running_commands.minimum_duration_seconds = 10
notification.exceptions.handled.enabled = false
notification.exceptions.unhandled.enabled = false
notification.overview.max_items = 30
notifications.app.available = true
notifications.app.enabled = true
notifications.app.duration_seconds = 5
notifications.os.available = false
notifications.os.enabled = false
command_palette.mode  = visible
terminal.webgl = true
terminal.inactive_overlay_opacity = 30
terminal.allow_transparency = true
terminal.tab_stop_width = 8
terminal.minimum_contrast_ratio = 4
terminal.screen_reader_mode = false
terminal.word_separator = "()[]{}'\"\\,;:/&<>*+=$^!~` "
terminal.progress_bar.enabled = true
search.mode  = visible
search.match.background_color = 2f8fda55
search.match.border_color = 2f8fda
search.match.overview_ruler_color = 2f8fda
search.active_match.background_color = f5e66399
search.active_match.border_color = f5e663
search.active_match.overview_ruler_color = f5e663
