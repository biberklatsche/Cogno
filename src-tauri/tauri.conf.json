{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cogno",
  "version": "0.4.0",
  "identifier": "rocks.cogno",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist/cogno/browser"
  },
  "app": {
    "windows": [],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/*",
          "$HOME/.cogno-dev/**",
          "$HOME/.cogno/**",
          "$HOME/.cogno/shell-integration/zsh/.zshrc",
          "$HOME/.cogno-dev/shell-integration/zsh/.zshrc"
        ]
      },
      "csp": "default-src 'self' blob: data: filesystem: ws: wss: http: https: tauri: 'unsafe-eval' 'unsafe-inline'; img-src 'self' asset: file: data: blob: http://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "The terminal for the AI era.",
    "longDescription": "Cogno is a terminal emulator built for the AI era — with smart autocomplete, command history intelligence, and a clean, fast interface.",
    "licenseFile": "../LICENSE",
    "category": "DeveloperTool",
    "icon": [
      "icons/16x16.png",
      "icons/32x32.png",
      "icons/48x48.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "resources": [
      "../src/packages/assets/src/assets/**/*",
      "src/default_windows.config",
      "src/default_linux.config",
      "src/default_macos.config"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "infoPlist": "Info.plist",
      "dmg": {
        "background": "assets/dmg-background.png",
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 160 },
        "applicationFolderPosition": { "x": 480, "y": 160 }
      }
    }
  }
}
