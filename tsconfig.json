/* To learn more about this file see: https://angular.io/config/tsconfig. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "baseUrl": ".",
    "paths": {
      "@cogno/core-sdk": ["src/packages/core-sdk/index.ts"],
      "@cogno/core-sdk/*": ["src/packages/core-sdk/*"],
      "@cogno/core-host": ["src/packages/core-host/index.ts"],
      "@cogno/core-host/*": ["src/packages/core-host/*"],
      "@cogno/core-ui": ["src/packages/core-ui/index.ts"],
      "@cogno/core-ui/*": ["src/packages/core-ui/*"],
      "@cogno/app-shell/*": ["src/packages/app-shell/*"],
      "@cogno/app": ["src/app/main.ts"],
      "@cogno/app/*": ["src/app/*"],
      "@cogno/base-features": ["src/packages/base-features/index.ts"],
      "@cogno/base-features/*": ["src/packages/base-features/*"]
    },
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "declaration": false,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "useDefineForClassFields": false
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  }
}
