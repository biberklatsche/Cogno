/* To learn more about this file see: https://angular.io/config/tsconfig. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "baseUrl": ".",
    "paths": {
      "@cogno/core-api": ["src/packages/core-api/index.ts"],
      "@cogno/core-api/*": ["src/packages/core-api/*"],
      "@cogno/feature-api": ["src/packages/feature-api/index.ts"],
      "@cogno/feature-api/*": ["src/packages/feature-api/*"],
      "@cogno/core-domain": ["src/packages/core-domain/index.ts"],
      "@cogno/core-domain/*": ["src/packages/core-domain/*"],
      "@cogno/core-host": ["src/packages/core-host/index.ts"],
      "@cogno/core-host/*": ["src/packages/core-host/*"],
      "@cogno/core-ui": ["src/packages/core-ui/index.ts"],
      "@cogno/core-ui/*": ["src/packages/core-ui/*"],
      "@cogno/core-support": ["src/packages/core-support/index.ts"],
      "@cogno/core-support/*": ["src/packages/core-support/*"],
      "@cogno/app-tauri": ["src/packages/app-tauri/index.ts"],
      "@cogno/app-tauri/*": ["src/packages/app-tauri/*"],
      "@cogno/app": ["src/packages/app/app.component.ts"],
      "@cogno/app/*": ["src/packages/app/*"],
      "@cogno/app-setup": ["src/app/main.ts"],
      "@cogno/app-setup/*": ["src/app/*"],
      "@cogno/features": ["src/packages/features/index.ts"],
      "@cogno/features/*": ["src/packages/features/*"]
    },
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "declaration": false,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "useDefineForClassFields": false
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  }
}
